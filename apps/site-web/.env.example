# 后端 API 地址（生产环境替换为真实域名）
# 注意：NEXT_PUBLIC_* 变量在 docker build 时通过 --build-arg 传入，不能只在运行时设置
NEXT_PUBLIC_SITE_API_BASE_URL=https://api.dreamlog.com/api/v1

# 阿里云 OSS 公开访问地址（用于 Next.js 图片域名白名单）
# 格式: https://<bucket>.<region>.aliyuncs.com
# 如果不使用 Next.js <Image> 组件，可以留空
NEXT_PUBLIC_OSS_HOST=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
